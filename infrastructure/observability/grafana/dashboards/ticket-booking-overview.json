{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Service up",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\".+-service|api-gateway\"}",
          "legendFormat": "{{application}}"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}}},
            {"type": "value", "options": {"1": {"text": "UP", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate (per service)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx rate (per service)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency (per service)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (application, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "JVM heap used",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "type": "timeseries",
      "title": "Process CPU usage",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 6,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "min": 0}}
    },
    {
      "type": "timeseries",
      "title": "Live threads",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 7,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ticket-booking", "spring-boot"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
  "timezone": "",
  "title": "Ticket Booking - Services Overview",
  "uid": "ticket-booking-overview",
  "version": 1,
  "weekStart": ""
}
